generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(cuid())
  email                  String         @unique
  emailVerified          DateTime?
  displayName            String?
  notifyOnItemAdded      Boolean        @default(true)
  createdAt              DateTime       @default(now())
  lists                  List[]
  memberships            ListMember[]
  sessions               Session[]
  accounts               Account[]
  reviews                Review[]
  notifications          Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")
  addedItems             ListItem[]     @relation("ItemAddedBy")
  reminders              Reminder[]
}

model List {
  id            String         @id @default(cuid())
  name          String
  description   String?
  type          ListType       @default(PERSONAL)
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members       ListMember[]
  items         ListItem[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([ownerId])
}

enum ListType {
  PERSONAL
  SHARED
}

model ListMember {
  id       String     @id @default(cuid())
  listId   String
  userId   String
  role     MemberRole @default(VIEWER)
  list     List       @relation(fields: [listId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime   @default(now())

  @@unique([listId, userId])
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

model Title {
  id             String     @id @default(cuid())
  imdbId         String     @unique
  title          String
  year           String?
  type           TitleType
  posterUrl      String?
  plot           String?
  imdbRating     String?
  rtScore        String?
  contentRating  String?
  runtimeMinutes Int?
  genre          String?
  director       String?
  actors         String?
  totalSeasons   String?
  totalEpisodes  Int?
  airingSeasonNumber Int?
  metaFetchedAt  DateTime?
  listItems      ListItem[]
}

enum TitleType {
  MOVIE
  SERIES
}

model ListItem {
  id               String      @id @default(cuid())
  listId           String
  titleId          String
  list             List        @relation(fields: [listId], references: [id], onDelete: Cascade)
  title            Title       @relation(fields: [titleId], references: [id])
  addedById        String
  addedBy          User        @relation("ItemAddedBy", fields: [addedById], references: [id])
  recommendedBy    String?
  streamingService String?
  allEpisodesAvail Boolean?
  currentSeason    Int?
  notes            String?
  watchStatus      WatchStatus @default(UNWATCHED)
  watchedAt        DateTime?
  archivedAt       DateTime?
  priority         Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  reviews          Review[]
  notifications    Notification[]
  reminders        Reminder[]

  @@unique([listId, titleId])
  @@index([titleId])
}

enum WatchStatus {
  UNWATCHED
  WATCHING
  WATCHED
  DROPPED
}

model Review {
  id         String   @id @default(cuid())
  listItemId String
  userId     String
  rating     Int
  comment    String?
  listItem   ListItem @relation(fields: [listItemId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([listItemId, userId])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType @default(ITEM_ADDED)
  listId     String
  list       List             @relation(fields: [listId], references: [id], onDelete: Cascade)
  listItemId String?
  listItem   ListItem?        @relation(fields: [listItemId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  message    String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId, read])
}

enum NotificationType {
  ITEM_ADDED
  REMINDER
}

model Reminder {
  id         String    @id @default(cuid())
  listItemId String
  listItem   ListItem  @relation(fields: [listItemId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  remindAt   DateTime
  note       String?
  firedAt    DateTime?
  createdAt  DateTime  @default(now())

  @@unique([listItemId, userId])
  @@index([remindAt, firedAt])
}

// NextAuth.js models (email/magic-link provider)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
